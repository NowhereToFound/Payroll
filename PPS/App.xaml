<Application x:Class="PPS.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters (globally available) -->
            <converters:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
            <converters:InverseBoolToVisibilityConverter  x:Key="InverseBoolToVisibility"/>
            <converters:InverseBoolConverter              x:Key="InverseBool"/>
            <converters:NullToVisibilityConverter         x:Key="NullToVisibility"/>
            <converters:DecimalToCurrencyConverter        x:Key="DecimalToCurrency"/>
            <converters:PayPeriodToStringConverter        x:Key="PayPeriodToString"/>
            <converters:EnumToStringConverter             x:Key="EnumToString"/>
            <converters:BoolToStatusConverter             x:Key="BoolToStatus"/>
            <converters:LoanStatusToColorConverter        x:Key="LoanStatusToColor"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
