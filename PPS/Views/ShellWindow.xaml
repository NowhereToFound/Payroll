<Window x:Class="PPS.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PPS.ViewModels"
        xmlns:pages="clr-namespace:PPS.Views.Pages"
        Title="SDSC Payroll Processing System"
        Height="760" Width="1280"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                <pages:DashboardPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EmployeeListViewModel}">
                <pages:EmployeesPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
                <pages:AttendancePage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PayrollProcessViewModel}">
                <pages:PayrollPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:LoanViewModel}">
                <pages:LoansPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                <pages:ReportsPage/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SystemLogViewModel}">
                <pages:SystemLogPage/>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="40" ShadowDepth="4"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 SIDEBAR
            ══════════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo / App Name -->
                    <StackPanel Grid.Row="0" Margin="20,24,20,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <!-- SDSC School Logo -->
                            <Border Width="44" Height="44" CornerRadius="8"
                                    Background="White" Margin="0,0,10,0" Padding="3">
                                <Image Source="pack://application:,,,/SDSCLogo.jpg"
                                       Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="SDSC" FontSize="16" FontWeight="Black" Foreground="White"/>
                                <TextBlock Text="Payroll System" FontSize="9" Foreground="{StaticResource SidebarTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Height="1" Margin="0,16,0,0" Fill="#20FFFFFF"/>
                    </StackPanel>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="1" Margin="0,4,0,0">
                        <TextBlock Text="MAIN MENU" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#50C8D8E8" Margin="24,0,0,8"/>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsDashboardSelected}"
                                     Command="{Binding GoToDashboardCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⊞" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsEmployeesSelected}"
                                     Command="{Binding GoToEmployeesCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Employees" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsAttendanceSelected}"
                                     Command="{Binding GoToAttendanceCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📅" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Attendance" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsPayrollSelected}"
                                     Command="{Binding GoToPayrollCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="₱" FontSize="16" FontWeight="Bold" Margin="0,0,12,0" VerticalAlignment="Center"
                                           Width="16" TextAlignment="Center"/>
                                <TextBlock Text="Payroll" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsLoansSelected}"
                                     Command="{Binding GoToLoansCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💳" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Loans" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsReportsSelected}"
                                     Command="{Binding GoToReportsCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Reports" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>

                        <Rectangle Height="1" Margin="16,8" Fill="#20FFFFFF"/>

                        <RadioButton GroupName="Nav"
                                     IsChecked="{Binding IsSystemLogSelected}"
                                     Command="{Binding GoToSystemLogCommand}"
                                     Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="System Logs" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <!-- Bottom user / logout -->
                    <Border Grid.Row="2" BorderBrush="#20FFFFFF" BorderThickness="0,1,0,0" Padding="16,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding CurrentUserName}" FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="{Binding CurrentUserRole}" FontSize="10" Foreground="{StaticResource SidebarTextBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="⏻"
                                    Command="{Binding LogoutCommand}"
                                    Width="34" Height="34"
                                    Background="#20FFFFFF"
                                    Foreground="White"
                                    BorderThickness="0"
                                    FontSize="16"
                                    Cursor="Hand"
                                    ToolTip="Logout">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                                CornerRadius="6" Width="34" Height="34">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{StaticResource ErrorBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 MAIN CONTENT AREA
            ══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Column="1" Background="{StaticResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top bar -->
                <Border Grid.Row="0" Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CurrentViewModel.Title}"
                                   Style="{StaticResource HeadingMedium}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                            <TextBlock x:Name="TodayLabel"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- Drag handle -->
                        <Border Grid.ColumnSpan="2" Background="Transparent"
                                MouseLeftButtonDown="TopBar_MouseDown"/>
                    </Grid>
                </Border>

                <!-- Page content (DataTemplate-resolved) -->
                <ContentControl Grid.Row="1"
                                Content="{Binding CurrentViewModel}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
