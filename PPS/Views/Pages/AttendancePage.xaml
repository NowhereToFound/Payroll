<UserControl x:Class="PPS.Views.Pages.AttendancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
            <converters:NullToVisibilityConverter  x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource HeadingLarge}" Text="Attendance Records"/>
            <TextBlock Style="{StaticResource BodyText}" Text="Import biometric CSV or manage attendance manually"/>
        </StackPanel>

        <!-- Period + Employee selectors + Import -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="YEAR" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                              Style="{StaticResource FormComboBox}" Width="80"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="MONTH" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                              Style="{StaticResource FormComboBox}" Width="70"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="PERIOD" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}"
                              Style="{StaticResource FormComboBox}" Width="160"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="EMPLOYEE" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding EmployeeList}"
                              SelectedItem="{Binding SelectedEmployee}"
                              DisplayMemberPath="FullName"
                              Style="{StaticResource FormComboBox}"/>
                </StackPanel>
                <Button Grid.Column="8" Content="📂 Import CSV"
                        Command="{Binding ImportCsvCommand}"
                        Style="{StaticResource AccentButton}"
                        VerticalAlignment="Bottom"/>
                <Button Grid.Column="10" Content="Refresh"
                        Command="{Binding LoadRecordsCommand}"
                        Style="{StaticResource OutlineButton}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Messages -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <Border Style="{StaticResource ErrorMessage}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                    Margin="0,0,0,6">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
            </Border>
            <Border Style="{StaticResource SuccessMessage}"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"/>
            </Border>
        </StackPanel>

        <!-- Attendance Grid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Records}"
                      Style="{StaticResource AppDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      CanUserDeleteRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DATE"          Binding="{Binding Date}"           Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="TIME IN"       Binding="{Binding TimeIn}"         Width="100"/>
                    <DataGridTextColumn Header="TIME OUT"      Binding="{Binding TimeOut}"        Width="100"/>
                    <DataGridTextColumn Header="LATE (min)"    Binding="{Binding LateMinutes, StringFormat=N1}" Width="100"/>
                    <DataGridTextColumn Header="OT (hrs)"      Binding="{Binding OvertimeHours, StringFormat=N2}" Width="90"/>
                    <DataGridComboBoxColumn Header="LEAVE TYPE"
                                            SelectedItemBinding="{Binding LeaveType}"
                                            Width="130"/>
                    <DataGridCheckBoxColumn Header="ABSENT"    Binding="{Binding IsAbsent}"       Width="80"/>
                    <DataGridTextColumn Header="REMARKS"       Binding="{Binding Remarks}"        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading -->
        <Grid Grid.RowSpan="4" Style="{StaticResource BusyOverlay}"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading attendance records…" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
