<UserControl x:Class="PPS.Views.Pages.LoansPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
            <converters:NullToVisibilityConverter  x:Key="NullToVisibility"/>
            <converters:DecimalToCurrencyConverter x:Key="Currency"/>
            <converters:LoanStatusToColorConverter x:Key="LoanStatusColor"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: Loan List -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Style="{StaticResource HeadingLarge}" Text="Loan Management"/>
                <TextBlock Style="{StaticResource BodyText}" Text="SSS, Pag-IBIG, and Company on-hand loans"/>
            </StackPanel>

            <!-- Employee + Add button -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="SELECT EMPLOYEE" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding EmployeeList}"
                              SelectedItem="{Binding SelectedEmployee}"
                              DisplayMemberPath="FullName"
                              Style="{StaticResource FormComboBox}"/>
                </StackPanel>
                <Button Grid.Column="2" Content="+ New Loan"
                        Command="{Binding ShowAddPanelCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom"/>
            </Grid>

            <!-- Messages -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <Border Style="{StaticResource ErrorMessage}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,6">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
                </Border>
                <Border Style="{StaticResource SuccessMessage}"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"/>
                </Border>
            </StackPanel>

            <!-- Loan DataGrid -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
                <DataGrid ItemsSource="{Binding LoanList}"
                          SelectedItem="{Binding SelectedLoan}"
                          Style="{StaticResource AppDataGrid}"
                          ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="TYPE"    Binding="{Binding LoanType}"      Width="110"/>
                        <DataGridTemplateColumn Header="AMOUNT" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding LoanAmount, Converter={StaticResource Currency}}"
                                               Style="{StaticResource CurrencyText}" Margin="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="BALANCE" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Balance, Converter={StaticResource Currency}}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource ErrorBrush}" Margin="12,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="AMORT/MO"
                                            Binding="{Binding MonthlyAmortization, StringFormat='₱{0:N2}'}"
                                            Width="110"/>
                        <DataGridTextColumn Header="SEMI-MO"
                                            Binding="{Binding SemiMonthlyAmortization, StringFormat='₱{0:N2}'}"
                                            Width="100"/>
                        <DataGridTemplateColumn Header="STATUS" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="8,2" Margin="8,0" HorizontalAlignment="Left">
                                        <Border.Background>
                                            <Binding Path="Status" Converter="{StaticResource LoanStatusColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="ACTION" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Pay Now"
                                            Command="{Binding DataContext.ShowPaymentPanelCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource AccentButton}"
                                            Padding="10,4" FontSize="11" Margin="8,0"
                                            Visibility="{Binding Status,
                                                Converter={StaticResource LoanStatusColor}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- RIGHT: Add Loan / Payment Panel -->
        <Grid Grid.Column="2">
            <!-- Add Loan Panel -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding IsAddPanelVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="New Loan" Style="{StaticResource HeadingMedium}" Margin="0,0,0,20"/>

                    <TextBlock Text="LOAN TYPE" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding LoanTypes}"
                              SelectedItem="{Binding NewLoanType}"
                              Style="{StaticResource FormComboBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="LOAN AMOUNT (₱)" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding NewLoanAmount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="MONTHLY AMORTIZATION (₱)" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding NewMonthlyAmort, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,12"/>

                    <TextBlock Text="START DATE" Style="{StaticResource LabelText}"/>
                    <DatePicker SelectedDate="{Binding NewStartDate}" Height="38" Margin="0,0,0,12"/>

                    <TextBlock Text="REMARKS" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding NewLoanRemarks, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Height="70" TextWrapping="Wrap" AcceptsReturn="True"
                             Margin="0,0,0,20"/>

                    <Button Content="Save Loan"
                            Command="{Binding SaveLoanCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelAddCommand}"
                            Style="{StaticResource OutlineButton}"/>
                </StackPanel>
            </Border>

            <!-- Manual Payment Panel -->
            <Border Style="{StaticResource Card}"
                    Visibility="{Binding IsPaymentPanelVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Record Payment" Style="{StaticResource HeadingMedium}" Margin="0,0,0,8"/>
                    <TextBlock Style="{StaticResource BodyText}" Margin="0,0,0,20">
                        <Run Text="Loan: "/>
                        <Run Text="{Binding SelectedLoan.LoanType}"/>
                        <LineBreak/>
                        <Run Text="Remaining Balance: "/>
                        <Run Text="{Binding SelectedLoan.Balance, Converter={StaticResource Currency}}"/>
                    </TextBlock>

                    <TextBlock Text="PAYMENT AMOUNT (₱)" Style="{StaticResource LabelText}"/>
                    <TextBox Text="{Binding ManualPaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}" Margin="0,0,0,20"/>

                    <Button Content="Record Payment"
                            Command="{Binding RecordPaymentCommand}"
                            Style="{StaticResource AccentButton}" Margin="0,0,0,8"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelAddCommand}"
                            Style="{StaticResource OutlineButton}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Loading -->
        <Grid Grid.ColumnSpan="3" Style="{StaticResource BusyOverlay}"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading loans…" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
