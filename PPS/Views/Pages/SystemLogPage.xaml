<UserControl x:Class="PPS.Views.Pages.SystemLogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:PPS.ViewModels"
      xmlns:models="clr-namespace:PPS.Models">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Severity badge converters via style triggers -->
            <Style x:Key="SeverityBadge" TargetType="Border">
                <Setter Property="CornerRadius"       Value="4"/>
                <Setter Property="Padding"            Value="8,3"/>
                <Setter Property="HorizontalAlignment" Value="Center"/>
                <Setter Property="Background"         Value="#1A2196F3"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Summary KPI bar -->
            <RowDefinition Height="Auto"/>   <!-- Filter toolbar -->
            <RowDefinition Height="*"/>      <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════
             KPI SUMMARY BAR
        ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <UniformGrid Rows="1" Columns="4">

                <!-- Total -->
                <Border Margin="0,0,12,0" CornerRadius="10" Background="{StaticResource BackgroundBrush}" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="TOTAL ENTRIES" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="{Binding TotalCount}"
                                   FontSize="28" FontWeight="Black"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Info -->
                <Border Margin="0,0,12,0" CornerRadius="10" Background="#EFF6FF" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="INFO" Style="{StaticResource LabelText}" Foreground="#1D4ED8"/>
                        <TextBlock Text="{Binding InfoCount}"
                                   FontSize="28" FontWeight="Black" Foreground="#2563EB"/>
                    </StackPanel>
                </Border>

                <!-- Warning -->
                <Border Margin="0,0,12,0" CornerRadius="10" Background="#FFFBEB" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="WARNING" Style="{StaticResource LabelText}" Foreground="#92400E"/>
                        <TextBlock Text="{Binding WarningCount}"
                                   FontSize="28" FontWeight="Black" Foreground="#D97706"/>
                    </StackPanel>
                </Border>

                <!-- Error -->
                <Border CornerRadius="10" Background="#FEF2F2" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="ERROR" Style="{StaticResource LabelText}" Foreground="#991B1B"/>
                        <TextBlock Text="{Binding ErrorCount}"
                                   FontSize="28" FontWeight="Black" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             FILTER TOOLBAR
        ══════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,12">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- From Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="From" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="130"
                                Style="{StaticResource FormDatePicker}"
                                VerticalAlignment="Center"/>
                </StackPanel>

                <!-- To Date -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="To" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="130"
                                Style="{StaticResource FormDatePicker}"
                                VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Severity filter -->
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0" VerticalAlignment="Center">
                    <TextBlock Text="Severity" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox ItemsSource="{Binding SeverityOptions}"
                              SelectedItem="{Binding SelectedSeverity}"
                              Width="110" Style="{StaticResource FormComboBox}"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Text search -->
                <Border CornerRadius="6" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" Padding="10,0"
                        Background="White" VerticalAlignment="Center" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 BorderThickness="0" Width="180" Height="34"
                                 VerticalContentAlignment="Center"
                                 FontSize="13"
                                 Background="Transparent"
                                 x:Name="SearchBox"/>
                    </StackPanel>
                </Border>

                <!-- Refresh -->
                <Button Content="↻  Refresh"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════
             LOG DATAGRID
        ══════════════════════════════════════════════════════════════ -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserResizeRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderBrush}"
                  RowHeight="38"
                  HeadersVisibility="Column"
                  ColumnHeaderHeight="38"
                  BorderThickness="0"
                  Background="White">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"  Value="White"/>
                    <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}"/>
                    <Setter Property="FontSize"    Value="11"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Padding"     Value="12,0"/>
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding"         Value="12,0"/>
                    <Setter Property="BorderThickness"  Value="0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                    <Setter Property="FontSize"         Value="13"/>
                    <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#EFF6FF"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="White"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F8FAFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- Timestamp -->
                <DataGridTextColumn Header="TIMESTAMP" Width="160"
                                    Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd  HH:mm:ss'}"/>

                <!-- Severity badge -->
                <DataGridTemplateColumn Header="SEVERITY" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate DataType="{x:Type models:SystemLog}">
                            <Border CornerRadius="4" Padding="8,3" HorizontalAlignment="Center"
                                    x:Name="SeverityBadge">
                                <TextBlock Text="{Binding Severity}" FontSize="11" FontWeight="SemiBold"
                                           x:Name="SeverityText"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="Info">
                                    <Setter TargetName="SeverityBadge" Property="Background" Value="#DBEAFE"/>
                                    <Setter TargetName="SeverityText"  Property="Foreground" Value="#1D4ED8"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                    <Setter TargetName="SeverityBadge" Property="Background" Value="#FEF3C7"/>
                                    <Setter TargetName="SeverityText"  Property="Foreground" Value="#92400E"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Severity}" Value="Error">
                                    <Setter TargetName="SeverityBadge" Property="Background" Value="#FEE2E2"/>
                                    <Setter TargetName="SeverityText"  Property="Foreground" Value="#991B1B"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- User -->
                <DataGridTextColumn Header="USER"   Width="120" Binding="{Binding Username}"/>

                <!-- Module -->
                <DataGridTextColumn Header="MODULE" Width="110" Binding="{Binding Module}"/>

                <!-- Action -->
                <DataGridTextColumn Header="ACTION" Width="*"   Binding="{Binding Action}"/>

                <!-- Details -->
                <DataGridTextColumn Header="DETAILS" Width="260"
                                    Binding="{Binding Details}">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

            </DataGrid.Columns>
        </DataGrid>

        <!-- Empty state -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Panel.ZIndex="1">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <!-- Show ONLY when loaded (not busy) AND no entries -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsBusy}"     Value="False"/>
                                <Condition Binding="{Binding TotalCount}" Value="0"/>
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="No log entries found" Style="{StaticResource HeadingMedium}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Adjust the date range or filters above"
                       Style="{StaticResource BodyText}" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Busy overlay -->
        <Border Grid.Row="2" Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading…" VerticalAlignment="Center" HorizontalAlignment="Center"
                       Style="{StaticResource HeadingMedium}"/>
        </Border>
    </Grid>
</UserControl>
