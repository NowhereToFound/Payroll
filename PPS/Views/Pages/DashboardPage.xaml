<UserControl x:Class="PPS.Views.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:DecimalToCurrencyConverter x:Key="Currency"/>
            <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Style="{StaticResource HeadingLarge}" Text="Dashboard"/>
            <TextBlock Style="{StaticResource BodyText}"
                       Text="{Binding CurrentPeriodLabel, StringFormat='Current Period: {0}'}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- KPI Cards Row -->
        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total Employees -->
            <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="40" Height="40" CornerRadius="10"
                                Background="#E8EDF8">
                            <TextBlock Text="👥" FontSize="18"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding TotalEmployees}"
                               FontSize="32" FontWeight="Black"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Total Employees" Style="{StaticResource BodyText}"/>
                    <TextBlock Margin="0,6,0,0" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="{Binding TeachingCount}"/>
                        <Run Text=" Teaching · "/>
                        <Run Text="{Binding NonTeachingCount}"/>
                        <Run Text=" Non-Teaching"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Payroll This Period -->
            <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                <Border.BorderBrush><SolidColorBrush Color="#D4A843" Opacity="0.4"/></Border.BorderBrush>
                <Border.BorderThickness>0,0,0,4</Border.BorderThickness>
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#FFF8E7" Margin="0,0,0,12" HorizontalAlignment="Left">
                        <TextBlock Text="₱" FontSize="18" FontWeight="Black"
                                   Foreground="{StaticResource AccentBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentPeriodNetPay, Converter={StaticResource Currency}}"
                               FontSize="24" FontWeight="Black"
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Net Pay This Period" Style="{StaticResource BodyText}"/>
                </StackPanel>
            </Border>

            <!-- Active Loans -->
            <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#FFF0F0" Margin="0,0,0,12" HorizontalAlignment="Left">
                        <TextBlock Text="💳" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding ActiveLoansCount}"
                               FontSize="32" FontWeight="Black"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Active Loan Accounts" Style="{StaticResource BodyText}"/>
                </StackPanel>
            </Border>

            <!-- Year -->
            <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                <StackPanel>
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="#E8F5E9" Margin="0,0,0,12" HorizontalAlignment="Left">
                        <TextBlock Text="📅" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="2026"
                               FontSize="32" FontWeight="Black"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Fiscal Year" Style="{StaticResource BodyText}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Compliance Info Panel -->
        <Border Grid.Row="2" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="2026 Statutory Compliance Rates"
                           Style="{StaticResource HeadingMedium}" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Border Background="#E3EDF7" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="SSS" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                                <TextBlock Text="15% Total" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Employee: 4.5%" FontSize="12"/>
                        <TextBlock Text="Employer: 10.5%" FontSize="12"/>
                        <TextBlock Text="Max MSC: ₱35,000" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,16,0">
                        <Border Background="#FFF3E0" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="PhilHealth" FontSize="16" FontWeight="Bold"
                                           Foreground="#E67E00"/>
                                <TextBlock Text="5.0% Total" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Employee: 2.5%" FontSize="12"/>
                        <TextBlock Text="Employer: 2.5%" FontSize="12"/>
                        <TextBlock Text="Cap: ₱5,000/month" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,16,0">
                        <Border Background="#E8F5E9" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Pag-IBIG" FontSize="16" FontWeight="Bold"
                                           Foreground="#2E7D32"/>
                                <TextBlock Text="Fixed Rate" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Employee: ₱200/mo" FontSize="12"/>
                        <TextBlock Text="Employer: ₱200/mo" FontSize="12"/>
                        <TextBlock Text="If salary &gt; ₱1,500" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <Border Background="#FCE4EC" CornerRadius="8" Padding="16,12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="BIR TRAIN" FontSize="16" FontWeight="Bold"
                                           Foreground="#C62828"/>
                                <TextBlock Text="Semi-Monthly" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="0% up to ₱10,417" FontSize="12"/>
                        <TextBlock Text="20%–35% brackets" FontSize="12"/>
                        <TextBlock Text="6-tier TRAIN table" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <Grid Grid.RowSpan="3" Style="{StaticResource BusyOverlay}"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading dashboard…" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
