<Window x:Class="PPS.Views.Pages.EmployeeDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PPS.Converters"
        Title="{Binding Title}"
        Height="640" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28">
                <!-- Messages -->
                <Border Style="{StaticResource ErrorMessage}"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                        Margin="0,0,0,12">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
                </Border>

                <!-- Row 1: Code + Type -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="EMPLOYEE CODE *" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding EmployeeCode, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="EMPLOYEE TYPE" Style="{StaticResource LabelText}"/>
                        <ComboBox ItemsSource="{Binding EmployeeTypes}"
                                  SelectedItem="{Binding EmployeeType}"
                                  Style="{StaticResource FormComboBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Name -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="LAST NAME *" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="FIRST NAME *" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="MIDDLE NAME" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3: Dept + Position -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="DEPARTMENT *" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding Department, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="POSITION *" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding Position, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4: Payroll Type + Salary/Rate -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="PAYROLL TYPE" Style="{StaticResource LabelText}"/>
                        <ComboBox ItemsSource="{Binding PayrollTypes}"
                                  SelectedItem="{Binding PayrollType}"
                                  Style="{StaticResource FormComboBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="BASIC MONTHLY SALARY (₱)" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding BasicMonthlySalary, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 5: Government Numbers -->
                <TextBlock Text="GOVERNMENT NUMBERS" Style="{StaticResource LabelText}" Margin="0,8,0,10"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="SSS NUMBER" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding SSSNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>
                        <TextBlock Text="PHILHEALTH NUMBER" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding PhilHealthNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="TIN NUMBER" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding TINNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}" Margin="0,0,0,10"/>
                        <TextBlock Text="PAG-IBIG NUMBER" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding PagIBIGNumber, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                </Grid>

                <!-- Row 6: Biometric + Date Hired -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="BIOMETRIC ID (matches CSV export)" Style="{StaticResource LabelText}"/>
                        <TextBox Text="{Binding BiometricId, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="DATE HIRED" Style="{StaticResource LabelText}"/>
                        <DatePicker SelectedDate="{Binding DateHired}" Height="38" FontSize="13"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0" Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Style="{StaticResource SuccessMessage}" Grid.Column="0"
                        Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibility}}">
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"/>
                </Border>
                <Button Grid.Column="1" Content="Cancel"
                        Style="{StaticResource OutlineButton}"
                        Click="CancelButton_Click"/>
                <Button Grid.Column="3" Content="Save Employee"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
