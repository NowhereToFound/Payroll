<UserControl x:Class="PPS.Views.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource HeadingLarge}" Text="Reports &amp; Government Remittance"/>
            <TextBlock Style="{StaticResource BodyText}" Text="Generate payroll summaries and SSS / PhilHealth / Pag-IBIG remittance schedules"/>
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="REPORT TYPE" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding ReportTypes}"
                              SelectedItem="{Binding SelectedReportType}"
                              Style="{StaticResource FormComboBox}"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="YEAR" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}"
                              Style="{StaticResource FormComboBox}" Width="80"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="MONTH" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}"
                              Style="{StaticResource FormComboBox}" Width="70"/>
                </StackPanel>
                <StackPanel Grid.Column="6">
                    <TextBlock Text="PERIOD" Style="{StaticResource LabelText}"/>
                    <ComboBox ItemsSource="{Binding Periods}" SelectedItem="{Binding SelectedPeriod}"
                              Style="{StaticResource FormComboBox}" Width="160"/>
                </StackPanel>
                <Button Grid.Column="8" Content="Generate Preview"
                        Command="{Binding GeneratePreviewCommand}"
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom"/>
                <Button Grid.Column="10" Content="📥 Export Excel"
                        Command="{Binding ExportExcelCommand}"
                        Style="{StaticResource AccentButton}"
                        VerticalAlignment="Bottom"/>
            </Grid>
        </Border>

        <!-- Messages -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <Border Style="{StaticResource ErrorMessage}"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                    Margin="0,0,0,6">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
            </Border>
            <Border Style="{StaticResource SuccessMessage}"
                    Visibility="{Binding SuccessMessage, Converter={StaticResource NullToVisibility}}">
                <TextBlock Text="{Binding SuccessMessage}" Foreground="{StaticResource SuccessBrush}"/>
            </Border>
        </StackPanel>

        <!-- Preview Area -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox Text="{Binding PreviewText}"
                         IsReadOnly="True"
                         Background="Transparent"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         FontSize="12"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         TextWrapping="NoWrap"
                         AcceptsReturn="True"/>
            </ScrollViewer>
        </Border>

        <!-- Loading -->
        <Grid Grid.RowSpan="4" Style="{StaticResource BusyOverlay}"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Generating report…" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
