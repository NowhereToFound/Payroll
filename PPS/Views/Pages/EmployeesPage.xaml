<UserControl x:Class="PPS.Views.Pages.EmployeesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PPS.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
            <converters:BoolToStatusConverter      x:Key="BoolToStatus"/>
            <converters:DecimalToCurrencyConverter x:Key="Currency"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="Auto"/>  <!-- Error message -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Style="{StaticResource HeadingLarge}" Text="Employee Master List"/>
            <TextBlock Style="{StaticResource BodyText}" Text="Manage all Teaching and Non-Teaching staff"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1.5"
                    Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal" Margin="12,0">
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="0" Background="Transparent"
                             VerticalAlignment="Center" FontSize="13"
                             MinWidth="250" Height="38"
                             Foreground="{StaticResource TextPrimaryBrush}">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="Search by name, code, department…"
                                                                   Foreground="#AABCCF" FontSize="13" Margin="2,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>
            </Border>

            <CheckBox Grid.Column="1" Content="Show Inactive"
                      IsChecked="{Binding ShowInactive}"
                      VerticalAlignment="Center" Margin="0,0,12,0"
                      FontSize="13"/>

            <Button Grid.Column="2" Content="+ Add Employee"
                    Command="{Binding AddEmployeeCommand}"
                    Style="{StaticResource PrimaryButton}"/>
        </Grid>

        <!-- Error Message (own row so it never overlaps toolbar) -->
        <Border Style="{StaticResource ErrorMessage}" Grid.Row="2"
                Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVisibility}}"
                Margin="0,0,0,8">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource ErrorBrush}"/>
        </Border>

        <!-- Employee Grid -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Employees}"
                      SelectedItem="{Binding SelectedEmployee}"
                      Style="{StaticResource AppDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="CODE"      Binding="{Binding EmployeeCode}" Width="90"/>
                    <DataGridTextColumn Header="LAST NAME" Binding="{Binding LastName}"     Width="140"/>
                    <DataGridTextColumn Header="FIRST NAME" Binding="{Binding FirstName}"   Width="140"/>
                    <DataGridTextColumn Header="DEPARTMENT" Binding="{Binding Department}"  Width="160"/>
                    <DataGridTextColumn Header="POSITION"  Binding="{Binding Position}"     Width="150"/>
                    <DataGridTextColumn Header="TYPE"      Binding="{Binding EmployeeType}" Width="110"/>
                    <DataGridTextColumn Header="PAY TYPE"  Binding="{Binding PayrollType}"  Width="110"/>
                    <DataGridTemplateColumn Header="BASIC SALARY" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding BasicMonthlySalary, Converter={StaticResource Currency}}"
                                           Style="{StaticResource CurrencyText}" Margin="12,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="STATUS" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="4" Padding="8,2" Margin="8,0"
                                        HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding IsActive, Converter={StaticResource BoolToStatus}}"
                                               FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="ACTIONS" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,0">
                                    <Button Content="Edit"
                                            Command="{Binding DataContext.EditEmployeeCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource OutlineButton}"
                                            Padding="10,4" FontSize="11" Margin="0,0,6,0"/>
                                    <Button Content="Deactivate"
                                            Command="{Binding DataContext.DeactivateEmployeeCommand,
                                                RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="10,4" FontSize="11"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Loading -->
        <Grid Grid.RowSpan="4" Style="{StaticResource BusyOverlay}"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="Loading employees…" FontSize="14"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
